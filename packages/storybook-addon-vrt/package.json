{
  "name": "storybook-addon-vrt",
  "version": "0.2.1",
  "description": "Self-contained visual regression testing for Storybook stories running on Vitest browser mode",
  "keywords": [
    "storybook-addon",
    "storybook",
    "vitest",
    "visual-regression-testing",
    "vrt",
    "screenshot",
    "test"
  ],
  "homepage": "https://github.com/k35o/storybook-addon-vrt#readme",
  "bugs": {
    "url": "https://github.com/k35o/storybook-addon-vrt/issues"
  },
  "license": "MIT",
  "author": "k8o",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k35o/storybook-addon-vrt.git",
    "directory": "packages/storybook-addon-vrt"
  },
  "bin": {
    "svrt": "./dist/cli.mjs"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./vitest-plugin": {
      "import": {
        "types": "./dist/vitest-plugin/index.d.mts",
        "default": "./dist/vitest-plugin/index.mjs"
      }
    },
    "./setup": {
      "import": {
        "types": "./dist/browser/setup.d.mts",
        "default": "./dist/browser/setup.mjs"
      }
    },
    "./internal/global-setup": {
      "import": {
        "default": "./dist/vitest-plugin/global-setup.mjs"
      }
    },
    "./preview": {
      "import": {
        "types": "./dist/preview.d.mts",
        "default": "./dist/preview.mjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "vp check",
    "check:write": "vp check --fix"
  },
  "dependencies": {
    "cac": "catalog:",
    "pixelmatch": "catalog:",
    "pngjs": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pngjs": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0",
    "vitest": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
