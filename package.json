{
  "name": "storybook-addon-vrt-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter storybook-addon-vrt build",
    "test": "pnpm --filter storybook-addon-vrt test",
    "e2e": "pnpm build && pnpm --filter example-basic e2e",
    "typecheck": "pnpm -r typecheck",
    "check": "pnpm -r check",
    "storybook": "pnpm build && pnpm --filter example-basic storybook"
  },
  "devDependencies": {
    "storybook-addon-vrt": "workspace:*",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=24.13.0"
  }
}
